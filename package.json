{
  "name": "nonis-card-house",
  "version": "0.1.0",
  "description": "A chunky, cartoon-styled card game prototype",
  "private": true,
  "scripts": {
    "predev": "node scripts/clean-stale-next-lock.mjs",
    "dev": "next dev -p 3002",
    "start": "next start -p 3002",
    "predev:next": "node scripts/clean-stale-next-lock.mjs",
    "dev:next": "next dev -p 3002",
    "build:next": "next build",
    "start:next": "next start -p 3002",
    "dev:api": "echo 'API is served by Next route handlers; run npm run dev'",
    "qa:migration": "node scripts/migration-qa.mjs",
    "db:migrate": "node server/scripts/migrate.js",
    "test:engine": "vitest run",
    "test": "vitest run"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.4",
    "pg": "^8.16.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=16"
  }
}
